<Window x:Class="AutomataSimulator.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:graph="clr-namespace:GraphShape.Controls;assembly=GraphShape.Controls"
        xmlns:models="clr-namespace:AutomataSimulator.WPF.Models"
        Title="Automata Simulator" Height="700" Width="1200">

    <Window.Resources>
        <DataTemplate DataType="{x:Type models:VisualVertex}">
            <Grid>
                <Ellipse Width="45" Height="45" Stroke="Black" StrokeThickness="2">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="White"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Fill" Value="#FFEB3B"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFinal}" Value="True">
                                    <Setter Property="Stroke" Value="Red"/>
                                    <Setter Property="StrokeThickness" Value="3"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:VisualEdge}">
            <TextBlock Text="{Binding Label}" Foreground="Blue" FontWeight="Bold" Background="White"/>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#F5F6F7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" Margin="10" CornerRadius="10" Padding="15">
            <StackPanel>
                <TextBlock Text="Конструктор" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
                <TextBox Text="{Binding SourceText, UpdateSourceTrigger=PropertyChanged}" Height="80" AcceptsReturn="True"/>
                <Button Content="Regex -> NFA" Command="{Binding TranslateRegexCommand}" Height="35" Margin="0,10,0,5"/>
                <Button Content="Grammar -> PDA" Command="{Binding TranslateGrammarCommand}" Height="35"/>
                <Separator Margin="0,20"/>
                <TextBlock Text="Тест:"/>
                <TextBox Text="{Binding TestInput, UpdateSourceTrigger=PropertyChanged}" FontSize="16"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" Margin="0,10" CornerRadius="10">
            <graph:GraphLayout x:Name="GraphLayout" 
                               LayoutAlgorithmType="FR" 
                               OverlapRemovalAlgorithmType="FSA" />
        </Border>

        <Border Grid.Column="2" Background="White" Margin="10" CornerRadius="10" Padding="15">
            <StackPanel DataContext="{Binding Simulation}">
                <Button Content="Шаг Вперед" Command="{Binding StepForwardCommand}" Height="45"/>
                <Button Content="Сброс" Command="{Binding ResetCommand}" Margin="0,5"/>
                <ListBox ItemsSource="{Binding StackView}" Height="250" Margin="0,20,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>